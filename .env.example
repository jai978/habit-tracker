# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# From: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Serverless functions (Vercel env vars, not exposed to browser) ────────────
# Supabase service role key — keep secret, never put in VITE_ vars
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — from resend.com → API Keys
RESEND_API_KEY=re_your_key

# The "From" address (must be a verified domain in Resend)
FROM_EMAIL=habits@yourdomain.com

# Your email address — where the daily check-in is sent
TO_EMAIL=jai@jpssolutions.co.nz

# The inbound address Resend routes replies to (set up in Resend → Inbound)
INBOUND_EMAIL=reply@habits.yourdomain.com

# Timezone for date calculations and email timestamps
TIMEZONE=Pacific/Auckland

# Random secret — Vercel passes this automatically to cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret
